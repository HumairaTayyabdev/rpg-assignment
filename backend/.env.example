PORT=3200
FRONTEND_ORIGIN=http://localhost:5173

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=rpg_user
DB_PASSWORD=rpg_password
DB_DATABASE=rpg_blog
TYPEORM_SYNCHRONIZE=true

AUTH_TOKEN_SECRET=replace-this-with-a-long-random-secret

# Redis for GraphQL subscription pub/sub (docker-compose exposes 6379).
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# Set to true for Jest or when Redis is not running (in-memory pub/sub only).
REDIS_DISABLED=false
